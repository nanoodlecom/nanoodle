+:root {
+  color-scheme: dark;
+  --bg: #1a1c28;
+  --card: #faf7f0;
+  --ink: #eae6de;
+  --ink-dark: #1a1a1a;
+  --dim: #8a8580;
+  --faint: #5a5550;
+  --accent: #d63040;
+  --ok: #2a9d5c;
+  --danger: #d63040;
+}
+* { box-sizing: border-box; }
+html, body { margin: 0; }
+body {
+  background-color: var(--bg);
+  background-image:
+    radial-gradient(circle, rgba(255,255,255,0.045) 1.2px, transparent 1.2px);
+  background-size: 6px 6px;
+  color: var(--ink);
+  font: 15px/1.55 ui-sans-serif, system-ui, sans-serif;
+  min-height: 100vh;
+}
+.app { max-width: 800px; margin: 0 auto; padding: 2rem 1.1rem 4rem; }
+
+/* ---- Header ---- */
+.app-head h1 {
+  font-size: 2rem;
+  font-weight: 900;
+  letter-spacing: 0.1em;
+  text-transform: uppercase;
+  margin: 0 0 0.3rem;
+  border-bottom: 4px solid var(--accent);
+  display: inline-block;
+  padding-bottom: 0.2rem;
+}
+#app-tagline { color: var(--dim); margin: 0.5rem 0 0; font-style: italic; max-width: 60ch; }
+.app-head .auth { font-size: 0.78rem; color: var(--dim); margin-top: 0.4rem; min-height: 1.1em; }
+
+/* ---- Input Cards ---- */
+.inputs { display: flex; flex-direction: column; gap: 1.2rem; margin: 1.6rem 0; }
+.field {
+  background: var(--card);
+  border: 3px solid var(--ink-dark);
+  box-shadow: 5px 5px 0 var(--ink-dark);
+  padding: 1rem 1.1rem;
+}
+.field label {
+  display: block;
+  font-size: 0.82rem;
+  font-weight: 900;
+  text-transform: uppercase;
+  letter-spacing: 0.08em;
+  color: var(--ink-dark);
+  margin-bottom: 0.4rem;
+  padding-bottom: 0.35rem;
+  border-bottom: 3px solid var(--accent);
+}
+.field input, .field textarea, .field select {
+  width: 100%; font: inherit; padding: 0.5rem 0.6rem;
+  border-radius: 0; background: #fff; border: 1.5px solid #bbb; color: var(--ink-dark);
+}
+.field textarea { min-height: 80px; resize: vertical; font-family: 'Courier New', monospace; font-size: 13px; line-height: 1.5; }
+
+/* ---- Run Button ---- */
+.run-row { display: flex; align-items: center; gap: 1rem; margin: 1.5rem 0 1.2rem; flex-wrap: wrap; }
+.run {
+  font: inherit; font-weight: 900; font-size: 1.15rem;
+  text-transform: uppercase; letter-spacing: 0.12em;
+  padding: 1rem 2.8rem; border-radius: 0; cursor: pointer;
+  background: var(--accent); border: 3px solid var(--ink-dark); color: #fff;
+  box-shadow: 5px 5px 0 var(--ink-dark);
+  transition: transform 0.08s, box-shadow 0.08s;
+}
+.run:hover { transform: translate(1px, 1px); box-shadow: 4px 4px 0 var(--ink-dark); }
+.run:active { transform: translate(4px, 4px); box-shadow: 1px 1px 0 var(--ink-dark); }
+
+/* ---- Status & Output ---- */
+.status { font-size: 0.82rem; color: var(--dim); min-height: 1.2em; display: flex; flex-direction: column; gap: 0.2rem; }
+.output { display: flex; flex-direction: column; gap: 1rem; }
+.output .card { background: var(--card); border: 3px solid var(--ink-dark); padding: 1rem; box-shadow: 5px 5px 0 var(--ink-dark); }
+.output img, .output video, .output audio { width: 100%; display: block; border: 3px solid var(--ink-dark); }
+.output .text { white-space: pre-wrap; line-height: 1.6; color: var(--ink-dark); }
+.output.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
+
+/* ---- Misc ---- */
+.loop { font-size: 0.85rem; color: var(--dim); }
+.count { font-size: 0.85rem; color: var(--dim); }
