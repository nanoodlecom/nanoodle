+.run-row{ display:flex; align-items:center; gap:1rem; margin:.4rem 0 1.2rem; flex-wrap:wrap; }
+.run{ font:inherit; font-weight:700; padding:.7rem 1.8rem; border-radius:var(--radius); cursor:pointer;
+  background:transparent; border:1px solid var(--cyan); color:var(--cyan);
+  letter-spacing:.25em; text-transform:uppercase; font-size:.82rem;
+  box-shadow:0 0 22px var(--cyan-soft); transition:all .15s; }
+.run:hover{ background:var(--cyan-soft); text-shadow:0 0 8px var(--cyan); }
