#!/bin/sh
# Block commits that introduce syntax errors in inline HTML JavaScript, and
# that break the standalone export (an exported app must run without nanoodle).
# Only runs when the relevant files are part of the commit.

set -e

root=$(git rev-parse --show-toplevel)
staged=$(git diff --cached --name-only --diff-filter=ACM)
staged_html=$(printf '%s\n' "$staged" | grep '\.html$' || true)
# play.html is the bundler; either checker can change what "self-contained" means.
touches_export=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-export\.mjs|scripts/check-html-js\.mjs)$' || true)
# index.html/play.html carry the OAuth login flow; the harness replays a sign-in round-trip.
touches_login=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-login-state\.mjs)$' || true)

# Nothing to check unless an .html file or one of the checkers changed.
[ -z "$staged_html" ] && [ -z "$touches_export" ] && [ -z "$touches_login" ] && exit 0

if ! command -v node >/dev/null 2>&1; then
  echo "pre-commit: node not found, skipping HTML JS checks" >&2
  exit 0
fi

# 1) inline HTML JavaScript must parse.
if [ -n "$staged_html" ]; then
  # shellcheck disable=SC2086
  node "$root/scripts/check-html-js.mjs" $staged_html
  # 1b) no third-party origins / CSP-unsafe constructs (eval, remote fonts…).
  # shellcheck disable=SC2086
  node "$root/scripts/check-policy.mjs" $staged_html
fi

# 2) the generated export must be self-contained (runs without nanoodle).
#    Cheap: no browser — bundles play.html in a node:vm sandbox and asserts the
#    output has no external deps, then node --checks its inline scripts.
if [ -n "$touches_export" ]; then
  node "$root/scripts/check-export.mjs"
fi

# 3) the user's app/graph must survive the OAuth login round-trip on every entry
#    path (#a=/#g=/#j=, My-Apps, local graph, near-full localStorage). Replays a
#    full sign-in redirect against the pages' real boot/signIn/handleRedirect code.
if [ -n "$touches_login" ]; then
  node "$root/scripts/check-login-state.mjs"
fi
