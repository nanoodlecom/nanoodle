#!/bin/sh
# Block commits that introduce syntax errors in inline HTML JavaScript, and
# that break the standalone export (an exported app must run without nanoodle).
# Only runs when the relevant files are part of the commit.

set -e

root=$(git rev-parse --show-toplevel)
staged=$(git diff --cached --name-only --diff-filter=ACM)
staged_html=$(printf '%s\n' "$staged" | grep '\.html$' || true)
# play.html is the bundler; either checker can change what "self-contained" means.
touches_export=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-export\.mjs|scripts/check-html-js\.mjs)$' || true)
# index.html/play.html carry the OAuth login flow; the harness replays a sign-in round-trip.
touches_login=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-login-state\.mjs)$' || true)
# sw.js decides which shell each route gets — wrong fallback shows the wrong app.
touches_sw=$(printf '%s\n' "$staged" | grep -E '(^|/)(sw\.js|scripts/check-sw-routing\.mjs)$' || true)
# play.html defines the workflow-compatibility classifier the edit-workflow round-trip relies on.
touches_compat=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-workflow-compat\.mjs)$' || true)
# play.html carries the run engine — old workflows must keep producing identical NanoGPT calls.
touches_run=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-run-compat\.mjs)$' || true)
# play.html carries the deterministic-skip cache (fixed-seed reuse + keep-mode hot-loop guard).
touches_seedcache=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-seed-cache\.mjs)$' || true)
# index.html carries the editor's dynamic image-input port logic (growth, compaction).
touches_imgports=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-image-ports\.mjs)$' || true)
# index.html carries the link-removal path (unlocking text fields when their source is deleted).
touches_editorports=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-editor-ports\.mjs)$' || true)
# play.html surfaces the per-node settings (swappable models, sizes…) the app's "Optional settings" panel renders.
touches_settings=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-app-settings\.mjs)$' || true)
# index.html carries the quick-add type filter (drop a wire into empty space → only fitting nodes).
touches_quickadd=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-quickadd\.mjs)$' || true)
# updates.json feeds the in-app "📣 Updates" changelog — a bad hand edit must not ship.
touches_updates=$(printf '%s\n' "$staged" | grep -E '(^|/)(updates\.json|scripts/check-updates\.mjs)$' || true)
# index.html + play.html carry the "Create app" handoff state machine (which app a click targets).
touches_createapp=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-create-app\.mjs)$' || true)

# Nothing to check unless an .html file or one of the checkers changed.
[ -z "$staged_html" ] && [ -z "$touches_export" ] && [ -z "$touches_login" ] && [ -z "$touches_sw" ] && [ -z "$touches_compat" ] && [ -z "$touches_run" ] && [ -z "$touches_seedcache" ] && [ -z "$touches_imgports" ] && [ -z "$touches_editorports" ] && [ -z "$touches_settings" ] && [ -z "$touches_quickadd" ] && [ -z "$touches_updates" ] && [ -z "$touches_createapp" ] && exit 0

if ! command -v node >/dev/null 2>&1; then
  echo "pre-commit: node not found, skipping HTML JS checks" >&2
  exit 0
fi

# 1) inline HTML JavaScript must parse.
if [ -n "$staged_html" ]; then
  # shellcheck disable=SC2086
  node "$root/scripts/check-html-js.mjs" $staged_html
  # 1b) no third-party origins / CSP-unsafe constructs (eval, remote fonts…).
  # shellcheck disable=SC2086
  node "$root/scripts/check-policy.mjs" $staged_html
fi

# 2) the generated export must be self-contained (runs without nanoodle).
#    Cheap: no browser — bundles play.html in a node:vm sandbox and asserts the
#    output has no external deps, then node --checks its inline scripts.
if [ -n "$touches_export" ]; then
  node "$root/scripts/check-export.mjs"
fi

# 3) the user's app/graph must survive the OAuth login round-trip on every entry
#    path (#a=/#g=/#j=, My-Apps, local graph, near-full localStorage). Replays a
#    full sign-in redirect against the pages' real boot/signIn/handleRedirect code.
if [ -n "$touches_login" ]; then
  node "$root/scripts/check-login-state.mjs"
fi

# 4) the service worker must serve the route-correct shell (never the editor for
#    /play), including the offline/network-miss fallback.
if [ -n "$touches_sw" ]; then
  node "$root/scripts/check-sw-routing.mjs"
fi

# 5) the workflow-compatibility classifier (keep-UI vs needs-port) must hold.
#    Cheap: no browser, no inference — runs the classifier from play.html over a
#    table of graph edits in a node:vm sandbox.
if [ -n "$touches_compat" ]; then
  node "$root/scripts/check-workflow-compat.mjs"
fi

# 6) backward-compat: old workflows must produce the SAME NanoGPT calls after the
#    LLM node gained dynamic image inputs. Drives the real runGraph() over a table
#    of graphs (+ the shipped noodle-graph.json) with a recording fetch.
if [ -n "$touches_run" ]; then
  node "$root/scripts/check-run-compat.mjs"
fi

# 6b) the deterministic-skip cache: a fixed-seed node reuses its output (no re-charge), a frozen
#     graph reports generated===0 so keep mode stops (no hot-loop), and a blank seed regenerates.
if [ -n "$touches_seedcache" ]; then
  node "$root/scripts/check-seed-cache.mjs"
fi

# 7) the editor's dynamic image-input ports must grow, disable, and COMPACT (no hole
#    left when a middle image source is removed). Extracts the real functions from
#    index.html and unit-tests them in a node:vm sandbox.
if [ -n "$touches_imgports" ]; then
  node "$root/scripts/check-image-ports.mjs"
fi

# 8) removing a node must unlock any text field it fed (no stuck-disabled prompt).
#    Runs the real refreshPortFills()/removeNode() over a tiny fake DOM.
if [ -n "$touches_editorports" ]; then
  node "$root/scripts/check-editor-ports.mjs"
fi

# 9) the "Optional settings" panel must surface every app's models (swappable)
#    plus the per-node knobs — and must keep them OUT of the IO signature, so a
#    model swap never reads as a breaking edit. Same node:vm sandbox technique.
if [ -n "$touches_settings" ]; then
  node "$root/scripts/check-app-settings.mjs"
fi

# 10) drop-a-wire-into-empty-space quick add must offer ONLY type-compatible nodes
#    (consumers when dragging from an output, producers when dragging from an input).
#    Runs the real filter functions over the real NODE_TYPES registry.
if [ -n "$touches_quickadd" ]; then
  node "$root/scripts/check-quickadd.mjs"
fi

# 11) the Updates changelog data must stay valid (newest-first array of
#     { date:"YYYY-MM-DD", text:"one line" }) so the in-app panel renders.
if [ -n "$touches_updates" ]; then
  node "$root/scripts/check-updates.mjs"
fi

# 12) the "Create app" handoff must route to the RIGHT app: a fresh workflow makes a NEW
#     app, an edited app's workflow UPDATES it (binding survives reload), the ✨ New escape
#     hatch unlinks, and an explicit handoff hash beats a stale resume stash. Drives the real
#     editor↔builder boot/handoff code in a node:vm sandbox across both pages.
if [ -n "$touches_createapp" ]; then
  node "$root/scripts/check-create-app.mjs"
fi
