#!/bin/sh
# Block commits that introduce syntax errors in inline HTML JavaScript, and
# that break the standalone export (an exported app must run without nanoodle).
# Only runs when the relevant files are part of the commit.

set -e

root=$(git rev-parse --show-toplevel)
staged=$(git diff --cached --name-only --diff-filter=ACM)
staged_html=$(printf '%s\n' "$staged" | grep '\.html$' || true)
# play.html is the bundler; either checker can change what "self-contained" means.
touches_export=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-export\.mjs|scripts/check-html-js\.mjs)$' || true)
# index.html/play.html carry the OAuth login flow; the harness replays a sign-in round-trip.
touches_login=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-login-state\.mjs)$' || true)
# sw.js decides which shell each route gets — wrong fallback shows the wrong app.
touches_sw=$(printf '%s\n' "$staged" | grep -E '(^|/)(sw\.js|scripts/check-sw-routing\.mjs)$' || true)
# play.html defines the workflow-compatibility classifier the edit-workflow round-trip relies on.
touches_compat=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-workflow-compat\.mjs)$' || true)
# play.html carries the run engine — old workflows must keep producing identical NanoGPT calls.
touches_run=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-run-compat\.mjs)$' || true)
# play.html's exported LLM node must gate response_format / input_audio by the model's real capability.
touches_llmgate=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-llm-capability-gates\.mjs|scripts/play-engine\.mjs)$' || true)
# play.html carries the deterministic-skip cache (fixed-seed reuse + keep-mode hot-loop guard).
touches_seedcache=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-seed-cache\.mjs)$' || true)
# index.html carries the editor's dynamic image-input port logic (growth, compaction).
touches_imgports=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-image-ports\.mjs)$' || true)
# index.html (I18N_LANGS) + the /xx/ landing pages + their generator carry the per-language SEO cluster.
touches_langpages=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|(es|fr|de|pt|ja)/index\.html|scripts/(gen|check)-lang-pages\.mjs)$' || true)
# index.html carries the link-removal path (unlocking text fields when their source is deleted).
touches_editorports=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-editor-ports\.mjs)$' || true)
# play.html surfaces the per-node settings (swappable models, sizes…) the app's "Optional settings" panel renders.
touches_settings=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-app-settings\.mjs)$' || true)
# index.html carries the quick-add type filter (drop a wire into empty space → only fitting nodes).
touches_quickadd=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-quickadd\.mjs)$' || true)
# index.html + play.html carry the i18n maps (editor + app-player/exported chrome) — a chrome string missing from every language map is invisible to users of all five.
touches_i18n=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-i18n-coverage\.mjs)$' || true)
# updates.json feeds the in-app "📣 Updates" changelog — a bad hand edit must not ship.
touches_updates=$(printf '%s\n' "$staged" | grep -E '(^|/)(updates\.json|scripts/check-updates\.mjs)$' || true)
# index.html + play.html carry the "Create app" handoff state machine (which app a click targets).
touches_createapp=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-create-app\.mjs)$' || true)
# index.html runGroup must not run/charge a downstream node on a failed upstream's stale output.
touches_stale=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-stale-input-charge\.mjs)$' || true)
# index.html + play.html carry the AI-upscale-through-Edit path (prompt-optional for /upscal/ models, blank prompt omitted from genImage) — the check pins both engines in lockstep.
touches_upscale=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-upscale\.mjs)$' || true)
# play.html runtime must resume a timed-out video job instead of re-submitting (double charge).
touches_vresume=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-video-resume\.mjs)$' || true)
# index.html + play.html carry the Share→Shorten flow; the short link must keep the #g=/#a= payload.
touches_share=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-share-link\.mjs)$' || true)
# index.html + play.html both carry the universal pricing resolver (every NanoGPT shape → a USD number:
# picker prices + "~$X to run" / "~$X / run" estimates); the check asserts both engines stay in lockstep.
touches_pricing=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-pricing\.mjs|scripts/pricing-fixtures\.json)$' || true)
# index.html + play.html carry the Combine node's lossless mp4 remux (MP4CAT); the check runs BOTH engines' copies on fixtures.
touches_combine=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-combine\.mjs|scripts/fixtures/clip[AB]\.mp4)$' || true)
# play.html's __api__ bridge paces spend-initiating calls from imported apps (token bucket); the check pins the charge/free split + budget.
touches_pacing=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-import-pacing\.mjs)$' || true)
# index.html carries graph persistence + share-payload packing (serialize/apply round-trip, legacy migrations,
# autosave-wipe protection, >64KB #g=/#j= pack) — drift silently loses work.
touches_graphpersist=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-graph-persistence\.mjs)$' || true)
# index.html signs the graph in three places (serializeGraph persists, appHandoffSig gates app-handoff/resume,
# contentSig gates copilot versioning) — a persisted node prop missing from the two sigs is silently dropped (PR #114).
touches_graphsigs=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-graph-sigs\.mjs)$' || true)
# index.html carries the "describe changes" copilot apply path (NL edit → graph rewrite → local validate/diff);
# its pure pre/post-processing must not destroy uploaded media or let an illegal paid option through.
touches_describeapply=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-describe-apply\.mjs)$' || true)
# index.html carries the API-key lifecycle & auth-clear state machine — a wrong clear condition
# logs a paying user out mid-run; a wrong accept condition stores an unsendable key that fails every run.
touches_authlc=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-auth-lifecycle\.mjs)$' || true)
# index.html carries the media-privacy sanitizers (strip remote beacons on import,
# blank the sharer's own uploads/inpaint media out of every share link).
touches_mediapriv=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-media-privacy\.mjs)$' || true)
# index.html + play.html carry the two append-only version strips (app-builder + Describe-changes copilot);
# the check pins no-truncation, media-aware park (H1), and every graph swap resetting the copilot chips.
touches_verhist=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-version-history\.mjs)$' || true)
# play.html carries the keyless/signed-out spend gating (PRs #216-#219): a fresh recipient must not be one
# click from an 8x/loop spend, and a signed-out Run must fire no API call.
touches_rungating=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-run-gating\.mjs)$' || true)
# play.html carries the "My apps" localStorage library — the user's ONLY durable copy of their built apps (no server).
touches_appsstorage=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-apps-storage\.mjs)$' || true)
# play.html carries the malformed/legacy #a= share-link path (#linkerr banner, hash retry, apps untouched).
touches_linkerr=$(printf '%s\n' "$staged" | grep -E '(^|/)(play\.html|scripts/check-linkerr\.mjs)$' || true)
# the deploy-config files (_headers CSP, sw.js cache stamp, _redirects, sitemap/robots/manifest) — the layer
# every in-page check passes AROUND; a drift here breaks prod while all other hooks stay green (PR #81 class).
touches_deploy=$(printf '%s\n' "$staged" | grep -E '(^|/)(_headers|_redirects|sw\.js|sitemap\.xml|robots\.txt|site\.webmanifest|index\.html|scripts/(check-deploy-config|stamp-sw|check-policy)\.mjs|scripts/fixtures/deploy-headers-csp\.golden\.json)$' || true)
# index.html + play.html carry the `hidden`-attribute vs author-`display:` hazard (an unguarded visible
# display: rule on a JS-hidden id keeps it visible — shipped once as /play's always-on #linkerr banner).
touches_hiddencss=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-hidden-css\.mjs)$' || true)
# index.html carries connect() (one wire per input, self-drop no-op) + topoOrder (run-time cycle guard).
touches_connect=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-connect-wires\.mjs)$' || true)
# index.html carries the undo/redo snapshot machine — the safety net that makes destructive edits
# (shared-link overwrite, 📂 Load file, describe-apply, delete) reversible.
touches_undo=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-undo-history\.mjs)$' || true)
# index.html + play.html carry the session cost-meter aggregation (spend total + balance chip) — the layer
# above check-pricing's per-unit estimators; zero-price must read known-free, never unknown.
touches_costaccrue=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-cost-accrue\.mjs)$' || true)
# index.html + play.html carry twin copies of resizePlan (Resize/crop geometry) — engine drift ships wrong
# dimensions into paid image/video jobs on one surface but not the other.
touches_resize=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|play\.html|scripts/check-resize-plan\.mjs)$' || true)
# index.html carries the model-catalog fetch/fallback/default-resolution layer — offline must yield a stable
# empty (no re-hammer), the cache primes first paint, and an empty catalog stays permissive (signed-off).
touches_catalog=$(printf '%s\n' "$staged" | grep -E '(^|/)(index\.html|scripts/check-catalog-fallback\.mjs)$' || true)

# Nothing to check unless an .html file or one of the checkers changed.
[ -z "$staged_html" ] && [ -z "$touches_export" ] && [ -z "$touches_login" ] && [ -z "$touches_sw" ] && [ -z "$touches_compat" ] && [ -z "$touches_run" ] && [ -z "$touches_seedcache" ] && [ -z "$touches_imgports" ] && [ -z "$touches_langpages" ] && [ -z "$touches_editorports" ] && [ -z "$touches_settings" ] && [ -z "$touches_quickadd" ] && [ -z "$touches_i18n" ] && [ -z "$touches_updates" ] && [ -z "$touches_createapp" ] && [ -z "$touches_stale" ] && [ -z "$touches_vresume" ] && [ -z "$touches_share" ] && [ -z "$touches_pricing" ] && [ -z "$touches_combine" ] && [ -z "$touches_pacing" ] && [ -z "$touches_graphpersist" ] && [ -z "$touches_graphsigs" ] && [ -z "$touches_describeapply" ] && [ -z "$touches_authlc" ] && [ -z "$touches_mediapriv" ] && [ -z "$touches_verhist" ] && [ -z "$touches_rungating" ] && [ -z "$touches_appsstorage" ] && [ -z "$touches_linkerr" ] && [ -z "$touches_deploy" ] && [ -z "$touches_hiddencss" ] && [ -z "$touches_connect" ] && [ -z "$touches_undo" ] && [ -z "$touches_costaccrue" ] && [ -z "$touches_resize" ] && [ -z "$touches_catalog" ] && [ -z "$touches_upscale" ] && exit 0

if ! command -v node >/dev/null 2>&1; then
  echo "pre-commit: node not found, skipping HTML JS checks" >&2
  exit 0
fi

# 1) inline HTML JavaScript must parse.
if [ -n "$staged_html" ]; then
  # shellcheck disable=SC2086
  node "$root/scripts/check-html-js.mjs" $staged_html
  # 1b) no third-party origins / CSP-unsafe constructs (eval, remote fonts…).
  # shellcheck disable=SC2086
  node "$root/scripts/check-policy.mjs" $staged_html
fi

# 2) the generated export must be self-contained (runs without nanoodle).
#    Cheap: no browser — bundles play.html in a node:vm sandbox and asserts the
#    output has no external deps, then node --checks its inline scripts.
if [ -n "$touches_export" ]; then
  node "$root/scripts/check-export.mjs"
fi

# 3) the user's app/graph must survive the OAuth login round-trip on every entry
#    path (#a=/#g=/#j=, My-Apps, local graph, near-full localStorage). Replays a
#    full sign-in redirect against the pages' real boot/signIn/handleRedirect code.
if [ -n "$touches_login" ]; then
  node "$root/scripts/check-login-state.mjs"
fi

# 4) the service worker must serve the route-correct shell (never the editor for
#    /play), including the offline/network-miss fallback.
if [ -n "$touches_sw" ]; then
  node "$root/scripts/check-sw-routing.mjs"
fi

# 5) the workflow-compatibility classifier (keep-UI vs needs-port) must hold.
#    Cheap: no browser, no inference — runs the classifier from play.html over a
#    table of graph edits in a node:vm sandbox.
if [ -n "$touches_compat" ]; then
  node "$root/scripts/check-workflow-compat.mjs"
fi

# 6) backward-compat: old workflows must produce the SAME NanoGPT calls after the
#    LLM node gained dynamic image inputs. Drives the real runGraph() over a table
#    of graphs (+ the shipped noodle-graph.json) with a recording fetch.
if [ -n "$touches_run" ]; then
  node "$root/scripts/check-run-compat.mjs"
fi

# 6a) exported-app LLM capability gating: a JSON output-format on a non-structured model, or a wired
#     audio clip on a text-only model, must be stripped from the PAYLOAD (not just the UI) so an exported
#     graph can't bill for a request the model returns empty / can't hear. Catalog-driven, permissive offline.
if [ -n "$touches_llmgate" ]; then
  node "$root/scripts/check-llm-capability-gates.mjs"
fi

# 6b) the deterministic-skip cache: a fixed-seed node reuses its output (no re-charge), a frozen
#     graph reports generated===0 so keep mode stops (no hot-loop), and a blank seed regenerates.
if [ -n "$touches_seedcache" ]; then
  node "$root/scripts/check-seed-cache.mjs"
fi

# 7) the editor's dynamic image-input ports must grow, disable, and COMPACT (no hole
#    left when a middle image source is removed). Extracts the real functions from
#    index.html and unit-tests them in a node:vm sandbox.
if [ -n "$touches_imgports" ]; then
  node "$root/scripts/check-image-ports.mjs"
fi

# 7b) the per-language landing pages (/es/ … /ja/) must exist for every app language, carry the
#     complete reciprocal hreflang cluster (incl. index.html) + a self-canonical, and never drift
#     from their generator. Keeps the i18n SEO cluster valid (one bad entry voids the whole thing).
if [ -n "$touches_langpages" ]; then
  node "$root/scripts/check-lang-pages.mjs"
fi

# 8) removing a node must unlock any text field it fed (no stuck-disabled prompt).
#    Runs the real refreshPortFills()/removeNode() over a tiny fake DOM.
if [ -n "$touches_editorports" ]; then
  node "$root/scripts/check-editor-ports.mjs"
fi

# 9) the "Optional settings" panel must surface every app's models (swappable)
#    plus the per-node knobs — and must keep them OUT of the IO signature, so a
#    model swap never reads as a breaking edit. Same node:vm sandbox technique.
if [ -n "$touches_settings" ]; then
  node "$root/scripts/check-app-settings.mjs"
fi

# 10) drop-a-wire-into-empty-space quick add must offer ONLY type-compatible nodes
#    (consumers when dragging from an output, producers when dragging from an input).
#    Runs the real filter functions over the real NODE_TYPES registry.
if [ -n "$touches_quickadd" ]; then
  node "$root/scripts/check-quickadd.mjs"
fi

# 11) the Updates changelog data must stay valid (newest-first array of
#     { date:"YYYY-MM-DD", text:"one line" }) so the in-app panel renders.
if [ -n "$touches_updates" ]; then
  node "$root/scripts/check-updates.mjs"
fi

# 12) the "Create app" handoff must route to the RIGHT app: a fresh workflow makes a NEW
#     app, an edited app's workflow UPDATES it (binding survives reload), the ✨ New escape
#     hatch unlinks, and an explicit handoff hash beats a stale resume stash. Drives the real
#     editor↔builder boot/handoff code in a node:vm sandbox across both pages.
if [ -n "$touches_createapp" ]; then
  node "$root/scripts/check-create-app.mjs"
fi

# 13) the editor's run engine must not charge a downstream node on a failed upstream's stale
#     output: a failed/cyclic node poisons its dependents, which are skipped (never run). Extracts
#     the real runGroup() and drives it with spy run()s in a node:vm sandbox.
if [ -n "$touches_stale" ]; then
  node "$root/scripts/check-stale-input-charge.mjs"
fi

# 13b) AI upscale runs through the Edit node: /upscal/ models take no instruction, so the
#      "no edit instruction" throw must be gated and genImage must omit a blank prompt — in
#      BOTH engines (recurring twin-drift risk). Source-assertion, no browser/network.
if [ -n "$touches_upscale" ]; then
  node "$root/scripts/check-upscale.mjs"
fi

# 14) the exported/standalone runtime must RESUME a video job that outlived the 10-min poll window
#     instead of re-submitting (and re-charging) it — while an edited node still submits afresh.
#     Drives the real runGraph() over a timing-out video graph with a recording fetch.
if [ -n "$touches_vresume" ]; then
  node "$root/scripts/check-video-resume.mjs"
fi

# 15) SHARE→SHORTEN: the copied link is fine, but the share flow strips the #a=/#g=
#     payload out of the address bar right after copying — so the shortener must be
#     handed the CAPTURED long link, not a rebuild from location.hash (empty by then),
#     or every TinyURL/da.gd short link opens an empty app. No browser, no network:
#     lifts openShareMenu() + the shorten handler out of both pages and drives them.
if [ -n "$touches_share" ]; then
  node "$root/scripts/check-share-link.mjs"
fi

# 16) PRICING: every NanoGPT pricing shape (35+ video variants, audio, chat) must resolve to a
#     USD number, or the model picker shows blank prices again and the "~$X to run" estimate breaks.
#     Offline: extracts the real videoUnitUsd/chatUnitUsd/audioUnitUsd out of index.html and runs
#     them over one captured fixture per live shape (scripts/pricing-fixtures.json). No API spend.
if [ -n "$touches_pricing" ]; then
  node "$root/scripts/check-pricing.mjs"
fi

# 17) COMBINE: the Combine node's lossless mp4 remux (MP4CAT in index.html) must produce an
#     exact-duration, correctly-tracked mp4. Offline: extracts the shipped remuxer and runs it on
#     two tiny committed fixtures. No browser, no ffmpeg, no API spend.
if [ -n "$touches_combine" ]; then
  node "$root/scripts/check-combine.mjs"
fi

# 19) IMPORTED-APP PACING: the __api__ bridge must run spend-initiating calls from imported apps
#     through a generous token bucket (own/preview apps + polling/catalog reads unmetered), so a
#     runaway loop is bounded and surfaced once instead of silently draining the viewer's balance.
#     Offline: lifts the real PACE bucket + classifyBridgePath() out of play.html and drives them.
if [ -n "$touches_pacing" ]; then
  node "$root/scripts/check-import-pacing.mjs"
fi

# 18) I18N: every static chrome string (title/placeholder/aria-label/group headers) in the editor
#     (index.html) AND the app player / exported chrome (play.html: PLAY_I18N + PLAY_I18N_B) must
#     exist in ALL five language maps or be explicitly allowlisted — strings missing from EVERY map
#     evade cross-language comparisons entirely. Also pins the t()/resolver/baked-lang mechanisms.
if [ -n "$touches_i18n" ]; then
  node "$root/scripts/check-i18n-coverage.mjs"
fi

# 20) GRAPH PERSISTENCE: serializeGraph/applyGraphData must round-trip a modern graph, migrate legacy
#     graphs (audio→tts, unknown-type skip, dangling-link prune, text→prompt port, id-counter rebuild),
#     protect the autosave from a throwing payload, and pack a >64KB graph byte-exact (#g= gzip + #j=
#     fallback). Offline: lifts the real functions out of index.html and runs them in a node:vm sandbox.
if [ -n "$touches_graphpersist" ]; then
  node "$root/scripts/check-graph-persistence.mjs"
fi

# 21) GRAPH SIGNATURES: serializeGraph (persist), appHandoffSig (app-handoff/resume) and contentSig
#     (copilot versioning) must cover the same node props — a new persisted prop missing from the sigs
#     is silently dropped from handoff/versioning (the PR #114 rename bug), and a signed-but-unpersisted
#     prop spuriously breaks identity. Mutation matrix over the real extracted functions.
if [ -n "$touches_graphsigs" ]; then
  node "$root/scripts/check-graph-sigs.mjs"
fi

# 22) DESCRIBE-CHANGES APPLY: the copilot's pure pre/post-processing must preserve a survivor's uploaded
#     media, respect the planner's deletions, snap out-of-range paid options to legal defaults, and
#     reject a cyclic/portless graph — all offline, no LLM.
if [ -n "$touches_describeapply" ]; then
  node "$root/scripts/check-describe-apply.mjs"
fi

# 23) AUTH LIFECYCLE: the stored key is cleared ONLY on a real 401/403 (never a benign 400/402/429/500
#     or network blip), a low-funds body can't masquerade as an auth error, an unsendable (non-ascii)
#     key is refused at paste time, and an unreachable nano-gpt leaves a good key "unverified" not "bad".
if [ -n "$touches_authlc" ]; then
  node "$root/scripts/check-auth-lifecycle.mjs"
fi

# 24) MEDIA PRIVACY: imported #g=/#j= links must have remote (beacon) upload/inpaint media stripped
#     BEFORE any element mounts (viewer IP/UA leak), and share links must blank the sharer's own
#     uploads/inpaint media — with both sanitizers pinned at their call sites.
if [ -n "$touches_mediapriv" ]; then
  node "$root/scripts/check-media-privacy.mjs"
fi

# 25) VERSION HISTORY: the two append-only version strips (play.html app-builder + index.html copilot)
#     must never truncate forward versions (the PR #63 "v4 lost my changes" bug), must park unsaved
#     media-only edits before jumping (audit H1), and every wholesale graph swap must reset the chips.
if [ -n "$touches_verhist" ]; then
  node "$root/scripts/check-version-history.mjs"
fi

# 26) KEYLESS SPEND GATING: with no key, run multipliers are forced to 1×/KEEP-off and hidden; the
#     run-cost chip scales usd × RUNS_N (never "$0"); a signed-out Run routes to the preflight and
#     fires ZERO fetch; typed inputs are stashed for the OAuth resume. (PRs #216-#219.)
if [ -n "$touches_rungating" ]; then
  node "$root/scripts/check-run-gating.mjs"
fi

# 27) MY-APPS STORAGE: the noodle_apps library (the user's only durable copy — no server) must load
#     corrupt-tolerantly, refuse-and-warn-once on quota (never silent-drop), delete only the target,
#     and round-trip every persisted field.
if [ -n "$touches_appsstorage" ]; then
  node "$root/scripts/check-apps-storage.mjs"
fi

# 28) MALFORMED SHARE LINKS: a truncated #a= (messengers wrap long URLs) must show the #linkerr banner —
#     never a blank page — keep the hash for a retry, and leave the recipient's saved apps untouched;
#     legacy 'u'-prefix links still open.
if [ -n "$touches_linkerr" ]; then
  node "$root/scripts/check-linkerr.mjs"
fi

# 29) DEPLOY CONFIG: _headers per-route CSP (single line per route, no cross-block /* intersection,
#     shortener + nano-gpt origins present, golden drift snapshot), sw.js CACHE stamp matches
#     stamp-sw.mjs's own regex + SHELL paths exist, /app + /editor rewrites, manifest/robots/sitemap
#     consistency, sitemap ↔ I18N_LANGS. The layer every in-page check passes AROUND (PR #81 class).
if [ -n "$touches_deploy" ]; then
  node "$root/scripts/check-deploy-config.mjs"
fi

# 30) HIDDEN vs display CSS: an author display: rule must not defeat the `hidden` attribute (element
#     shows while JS thinks it's hidden — shipped once as /play's always-on #linkerr banner). Static
#     scan of both pages' <style> subjects + JS hidden-toggles.
