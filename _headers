# Correct MIME for the web app manifest
/site.webmanifest
  Content-Type: application/manifest+json

# Don't let the service worker get stuck in a stale cache
/sw.js
  Cache-Control: no-cache

# Security headers for going live.
#
# The Content-Security-Policy is set PER PATH below, NOT on /*, on purpose: Cloudflare _headers
# COMBINES duplicate header values with a comma, so a page matching both /* and a more-specific
# rule would receive TWO CSP headers and the browser enforces their INTERSECTION (the tightest
# wins). That makes it impossible to *loosen* a global CSP for a sub-path. So each HTML entry
# point matches exactly one CSP rule, and /* carries only the non-CSP headers (which don't
# overlap, so they apply cleanly everywhere).
#
# Shared notes for the CSPs below:
# script-src keeps 'unsafe-inline' (every app is one big inline <script> with inline onclick handlers).
# patchling (formerly gptdiff-js) is vendored at /vendor/patchling (self-hosted ESM), so no third-party script origin is needed.
# img-src/media-src allow blob:/data: used for generated images (returned as b64 data: URLs) and
# download URLs. media-src additionally allows https: because generated music/video come back as
# URLs on provider CDNs (e.g. *.cloudfront.net) we don't control and can't enumerate — without it
# the <audio>/<video> source is blocked and the player shows a stuck 0:00.
# connect-src ALSO allows blob: (on every route, even tight ones): a node's output can be a blob:
# URL (e.g. Speech/Trim audio via createObjectURL), and the next node fetch()es those bytes to
# inline them (lipsync sends audio as a data URL). blob: plays under media-src but fetch() is gated
# by connect-src, so without it the bytes can't be read and you get a bare "Failed to fetch". A
# blob: URL is a same-origin in-memory reference the app made itself — fetching it is a local read,
# not network egress, so allowing it does NOT weaken play.html's anti-exfiltration (external) gate.
# frame/child/worker blob: cover the sandboxed app iframe.
# frame-ancestors 'self' (NOT 'none') so the editor (index.html) can frame play.html in the
# create-app modal; 'self' still blocks any external site from framing us (clickjacking).
# camera=(self) is required (index.html uses getUserMedia).
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(), geolocation=(), payment=(), usb=(), serial=(), bluetooth=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-origin

# Editor (index.html, served at / plus the /app and /editor rewrites). It runs only first-party
# code over DECLARATIVE graphs — never untrusted JS — so connect-src may include https:. That lets
# a media node's "save" button fetch generated music/video bytes back off the provider CDN and
# download them with a real filename; with connect-src tight, that fetch is blocked and "save" can
# only fall back to opening a tab (indistinguishable from "open").
/
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://nano-gpt.com; media-src 'self' data: blob: https:; connect-src 'self' blob: https://nano-gpt.com https:; frame-src 'self' blob:; child-src blob:; worker-src 'self' blob:; font-src 'self' data:; base-uri 'none'; form-action 'none'; object-src 'none'; frame-ancestors 'self'; upgrade-insecure-requests
/index.html
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://nano-gpt.com; media-src 'self' data: blob: https:; connect-src 'self' blob: https://nano-gpt.com https:; frame-src 'self' blob:; child-src blob:; worker-src 'self' blob:; font-src 'self' data:; base-uri 'none'; form-action 'none'; object-src 'none'; frame-ancestors 'self'; upgrade-insecure-requests
/app
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://nano-gpt.com; media-src 'self' data: blob: https:; connect-src 'self' blob: https://nano-gpt.com https:; frame-src 'self' blob:; child-src blob:; worker-src 'self' blob:; font-src 'self' data:; base-uri 'none'; form-action 'none'; object-src 'none'; frame-ancestors 'self'; upgrade-insecure-requests
/editor
