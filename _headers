# Localized landing pages (/es/ … /ja/, generated by scripts/gen-lang-pages.mjs). These are
# fully STATIC: inline CSS, one same-origin <img> (og-card.png) + favicons + manifest, zero
# scripts and zero network — they never call nano-gpt. Without an explicit block a /es/ request
# falls through to /* which carries NO CSP at all, so each path gets its own tight policy:
# default-src 'none' (no scripts, no connect, no frames) with just inline style + self images/manifest.
# Enumerated per-language ( _headers has no brace expansion ); one block per path (Cloudflare
# combines duplicates, so never two CSP lines for the same path).
/es/*
  Content-Security-Policy: default-src 'none'; img-src 'self'; style-src 'unsafe-inline'; manifest-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'self'; upgrade-insecure-requests
/fr/*
  Content-Security-Policy: default-src 'none'; img-src 'self'; style-src 'unsafe-inline'; manifest-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'self'; upgrade-insecure-requests
