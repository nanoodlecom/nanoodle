# Correct MIME for the web app manifest
/site.webmanifest
  Content-Type: application/manifest+json

# Don't let the service worker get stuck in a stale cache
/sw.js
  Cache-Control: no-cache

# Security headers for going live.
# script-src keeps 'unsafe-inline' (every app is one big inline <script> with inline onclick handlers).
# gptdiff-js is vendored at /vendor/gptdiff-js (self-hosted ESM), so no third-party script origin is needed.
# connect-src/img-src allow https://nano-gpt.com (the API) plus blob:/data: used for generated
# images (returned as b64 data: URLs) and download URLs. media-src additionally allows https:
# because generated music/video come back as URLs on provider CDNs (e.g. *.cloudfront.net) we
# don't control and can't enumerate — without it the <audio>/<video> source is blocked and the
# player shows a stuck 0:00. connect-src stays tight ('self' + nano-gpt.com) so an untrusted
# shared app still can't fetch-exfiltrate the viewer's inputs. frame/child/worker blob: cover the
# sandboxed app iframe.
# frame-ancestors 'self' (NOT 'none') so the editor (index.html) can frame play.html in the
# create-app modal; 'self' still blocks any external site from framing us (clickjacking).
# camera=(self) is required (index.html uses getUserMedia).
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://nano-gpt.com; media-src 'self' data: blob: https:; connect-src 'self' https://nano-gpt.com; frame-src 'self' blob:; child-src blob:; worker-src 'self' blob:; font-src 'self' data:; base-uri 'none'; form-action 'none'; object-src 'none'; frame-ancestors 'self'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
